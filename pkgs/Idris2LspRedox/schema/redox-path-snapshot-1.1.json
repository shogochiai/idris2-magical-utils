{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idris2-magical-utils.local/schema/redox-path-snapshot-1.1.json",
  "title": "Redox Path Snapshot Protocol 1.1",
  "type": "object",
  "required": ["protocolVersion", "schemaVersion", "methods"],
  "properties": {
    "protocolVersion": { "const": "1.1" },
    "schemaVersion": { "const": "1.1" },
    "methods": {
      "type": "array",
      "items": {
        "enum": [
          "idris2/redox/capabilities",
          "idris2/dumpPaths",
          "idris2/diffPaths",
          "idris2/getPathSnapshot",
          "idris2/getCurrentVerified",
          "idris2/preparePathPromotion",
          "idris2/promotePathSnapshot",
          "idris2/rejectPathSnapshot",
          "idris2/exportPathSnapshotStore",
          "idris2/importPathSnapshotStore"
        ]
      }
    },
    "snapshotPayload": { "$ref": "#/$defs/snapshotPayload" },
    "pathDiff": { "$ref": "#/$defs/pathDiff" },
    "promotionWitness": { "$ref": "#/$defs/promotionWitness" },
    "preparedPromotion": { "$ref": "#/$defs/preparedPromotion" }
  },
  "$defs": {
    "pathFact": {
      "type": "object",
      "required": ["lineageId", "revisionId", "specId"],
      "properties": {
        "lineageId": { "type": "string" },
        "revisionId": { "type": "string" },
        "definitionId": { "type": "string" },
        "caseAddress": { "type": "string" },
        "moduleId": { "type": "string" },
        "specId": { "type": "string" },
        "obligations": { "type": "array", "items": { "type": "string" } },
        "semanticHash": { "type": "string" },
        "sourceRange": {},
        "originDigest": { "type": "string" }
      },
      "additionalProperties": true
    },
    "snapshotPayload": {
      "type": "object",
      "required": [
        "projectId",
        "projectIdentity",
        "specRegistryDigest",
        "versions",
        "sourceDigest",
        "sourceDocumentDigest",
        "sourceTreeDigest",
        "compilerVersion",
        "harnessVersion",
        "schemaVersion",
        "elabStatus",
        "impactKind",
        "impactPrecision",
        "soundness",
        "paths",
        "invalidDefinitions",
        "dirtyModules",
        "diagnosticsDigest",
        "parentVerified",
        "origin"
      ],
      "properties": {
        "projectId": { "type": "string" },
        "projectIdentity": { "type": "object" },
        "specRegistryDigest": { "type": "string" },
        "versions": { "type": "object" },
        "sourceDigest": { "type": "string" },
        "sourceDocumentDigest": { "type": "string" },
        "sourceTreeDigest": { "type": "string" },
        "compilerVersion": {},
        "harnessVersion": {},
        "schemaVersion": {},
        "elabStatus": { "enum": ["Complete", "Partial", "Failed"] },
        "impactKind": { "const": "compiler-path" },
        "impactPrecision": {
          "enum": ["Exact", "DefinitionFallback", "ModuleFallback", "ProjectFallback"]
        },
        "soundness": { "const": "over-approximation" },
        "paths": { "type": "array", "items": { "$ref": "#/$defs/pathFact" } },
        "invalidDefinitions": { "type": "array", "items": { "type": "string" } },
        "dirtyModules": { "type": "array", "items": { "type": "string" } },
        "diagnosticsDigest": {},
        "parentVerified": { "type": ["string", "null"] },
        "origin": { "const": "idris2-lsp-redox" }
      },
      "additionalProperties": true
    },
    "pathDiff": {
      "type": "object",
      "required": [
        "removedFacts",
        "addedFacts",
        "modifiedBefore",
        "modifiedAfter",
        "unchangedLineages",
        "relocatedLineages",
        "fallbackFacts",
        "impactDirect",
        "impactClosed",
        "pathImpactDirect",
        "pathImpactClosed",
        "pathImpactDigest",
        "impactKind",
        "impactPrecision",
        "soundness",
        "completeness",
        "diffDigest",
        "pathDiffDigest"
      ],
      "properties": {
        "removedFacts": { "type": "object", "additionalProperties": { "$ref": "#/$defs/pathFact" } },
        "addedFacts": { "type": "object", "additionalProperties": { "$ref": "#/$defs/pathFact" } },
        "modifiedBefore": { "type": "object", "additionalProperties": { "$ref": "#/$defs/pathFact" } },
        "modifiedAfter": { "type": "object", "additionalProperties": { "$ref": "#/$defs/pathFact" } },
        "unchangedLineages": { "type": "array", "items": { "type": "string" } },
        "relocatedLineages": { "type": "array", "items": { "type": "string" } },
        "fallbackFacts": { "type": "object", "additionalProperties": { "$ref": "#/$defs/pathFact" } },
        "impactDirect": { "type": "array", "items": { "type": "string" } },
        "impactClosed": { "type": "array", "items": { "type": "string" } },
        "pathImpactDirect": { "type": "array", "items": { "type": "string" } },
        "pathImpactClosed": { "type": "array", "items": { "type": "string" } },
        "pathImpactDigest": { "type": "string" },
        "impactKind": { "const": "compiler-path" },
        "impactPrecision": {
          "enum": ["Exact", "DefinitionFallback", "ModuleFallback", "ProjectFallback"]
        },
        "soundness": { "const": "over-approximation" },
        "completeness": { "enum": ["Complete", "Partial", "Failed"] },
        "diffDigest": { "type": "string" },
        "pathDiffDigest": { "type": "string" }
      },
      "additionalProperties": false
    },
    "promotionWitness": {
      "type": "object",
      "required": [
        "workingSnapshotId",
        "pathImpactDigest",
        "verifiedPathSpecIds",
        "qeqVerifierVersion",
        "result"
      ],
      "properties": {
        "parentSnapshotId": { "type": "string" },
        "workingSnapshotId": { "type": "string" },
        "pathDiffDigest": { "type": "string" },
        "pathImpactDigest": { "type": "string" },
        "verifiedPathSpecIds": { "type": "array", "items": { "type": "string" } },
        "specRegistryDigest": { "type": "string" },
        "qeqVerifierVersion": { "type": "string" },
        "result": { "enum": [1, true] },
        "proofDigest": { "type": "string" },
        "logicalClock": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "preparedPromotion": {
      "type": "object",
      "required": [
        "snapshotId",
        "workingSnapshotId",
        "witness",
        "luciCertificateDigest",
        "pathProjectionDigest",
        "protocolVersion",
        "schemaVersion"
      ],
      "properties": {
        "snapshotId": { "type": "string" },
        "workingSnapshotId": { "type": "string" },
        "witness": { "$ref": "#/$defs/promotionWitness" },
        "luciCertificateDigest": { "type": ["string", "null"] },
        "pathProjectionDigest": { "type": "string" },
        "protocolVersion": { "const": "1.1" },
        "schemaVersion": { "const": "1.1" }
      },
      "additionalProperties": false
    }
  }
}
