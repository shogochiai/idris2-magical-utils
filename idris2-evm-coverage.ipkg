package idris2-evm-coverage
version = "0.1.0"
authors = "bob"
brief = "EVM semantic coverage analysis using Chez Scheme profiler"

depends = base, contrib

sourcedir = "src"

modules = EvmCoverage.Types
        , EvmCoverage.DumpcasesParser
        , EvmCoverage.ProfileParser
        , EvmCoverage.SchemeMapper
        , EvmCoverage.Aggregator
        , EvmCoverage.Report
        , EvmCoverage.EvmCoverage
        , Main

main = Main
executable = idris2-evm-cov
